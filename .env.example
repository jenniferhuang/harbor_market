# Copy to .env on the deployment host. Never commit the populated file.
COMPOSE_PROJECT_NAME=harbor-market
APP_PORT=8080

POSTGRES_DB=xiangyue_xiamen
POSTGRES_USER=harbor_market
POSTGRES_PASSWORD=replace-with-a-generated-password
AUTH_SECRET_KEY=replace-with-at-least-32-random-bytes
AUTH_COOKIE_NAME=harbor_market_session
AUTH_COOKIE_SECURE=true
AUTH_SESSION_TTL_SECONDS=28800

# Comma-separated public hostnames accepted by the API/proxy.
ALLOWED_HOSTS=localhost,127.0.0.1,app.hermes-node.com,*.trycloudflare.com
