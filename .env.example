# Copy to .env on the deployment host. Never commit the populated file.
COMPOSE_PROJECT_NAME=harbor-market
ENVIRONMENT=production
APP_PORT=8080

POSTGRES_DB=xiangyue_xiamen
POSTGRES_USER=harbor_market
POSTGRES_PASSWORD=replace-with-a-generated-password
AUTH_SECRET_KEY=replace-with-at-least-32-random-bytes
AUTH_COOKIE_NAME=harbor_market_session
AUTH_COOKIE_PATH=/api/v1
AUTH_COOKIE_SECURE=true
AUTH_SESSION_TTL_SECONDS=28800

# Generate unique values for both credentials. The S3 API remains Compose-private;
# only the MinIO console is available on the deployment host's loopback address.
# STORAGE_* is a separate least-privilege application identity. Compose fixes
# STORAGE_ENDPOINT=minio:9000 and STORAGE_SECURE=false inside the private network.
MINIO_ROOT_USER=replace-with-a-random-admin-access-key
MINIO_ROOT_PASSWORD=replace-with-at-least-32-random-characters
MINIO_CONSOLE_PORT=9001
MINIO_DATA_DIR=./.data/minio
STORAGE_BACKEND=minio
STORAGE_ACCESS_KEY=replace-with-a-different-random-app-access-key
STORAGE_SECRET_KEY=replace-with-a-different-32-character-secret
STORAGE_BUCKET=harbor-market-products
UPLOAD_MAX_BYTES=5242880
OBJECT_CLEANUP_INTERVAL_SECONDS=60

# Payment code is installed disabled. Mock mode is for local development/test
# only and Settings rejects it when ENVIRONMENT=production.
PAYMENT_MODE=disabled
PAYMENT_MOCK_CONTROLS_ENABLED=false
# Set only in a non-production .env when PAYMENT_MODE=mock. Never commit the value.
# PAYMENT_MOCK_SIGNING_SECRET=replace-with-at-least-32-random-characters
PAYMENT_MOCK_APP_ID=wx0000000000000000
PAYMENT_PREPAY_TTL_SECONDS=7200
PAYMENT_WEBHOOK_MAX_BYTES=1310720

# Comma-separated public hostnames accepted by the API/proxy.
ALLOWED_HOSTS=localhost,127.0.0.1,app.hermes-node.com,*.trycloudflare.com
# Safe only while the backend remains private behind the bundled Nginx service.
TRUST_PROXY_HEADERS=true
