<button
  class="product-card"
  bindtap="selectItem"
  aria-label="查看商品 {{item.name}}，价格 {{item.displayPrice}}"
>
  <image
    wx:if="{{item.coverUrl}}"
    class="product-card__image"
    src="{{item.coverUrl}}"
    mode="aspectFill"
    lazy-load="true"
    aria-label="{{item.name}} 商品图片"
  />
  <view wx:else class="product-card__image product-card__placeholder" aria-hidden="true">
    <text>Harbor</text>
  </view>

  <view class="product-card__body">
    <view class="product-card__meta">
      <text class="product-card__category">{{item.categoryName}}</text>
      <text wx:if="{{item.featured}}" class="product-card__featured">推荐</text>
    </view>
    <text class="product-card__name">{{item.name}}</text>
    <text wx:if="{{item.subtitle}}" class="product-card__subtitle">{{item.subtitle}}</text>
    <view class="product-card__footer">
      <text class="product-card__price">{{item.displayPrice}}</text>
      <text class="product-card__stock {{item.available ? '' : 'product-card__stock--empty'}}">
        {{item.stockLabel}}
      </text>
    </view>
  </view>
</button>
