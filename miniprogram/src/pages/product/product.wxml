<view class="product-page" aria-role="main">
  <view wx:if="{{loading}}" class="page-shell">
    <view class="surface status-panel" aria-role="status">
      <text class="status-panel__title">正在加载商品…</text>
      <text class="status-panel__message">请稍候</text>
    </view>
  </view>

  <view wx:elif="{{errorMessage}}" class="page-shell">
    <view class="surface status-panel" aria-role="alert">
      <text class="status-panel__title">商品加载失败</text>
      <text class="status-panel__message status-panel__message--error">{{errorMessage}}</text>
      <button class="secondary-button status-panel__action" bindtap="retry">重新加载</button>
    </view>
  </view>

  <block wx:elif="{{product}}">
    <view class="gallery" aria-label="商品图片">
      <swiper
        class="gallery__swiper"
        current="{{activeImageIndex}}"
        circular="{{images.length > 1}}"
        indicator-dots="{{images.length > 1}}"
        bindchange="onGalleryChange"
      >
        <swiper-item wx:for="{{images}}" wx:key="id">
          <image
            class="gallery__image"
            src="{{item.displayUrl}}"
            mode="aspectFill"
            aria-label="{{product.name}} 图片 {{index + 1}}"
          />
        </swiper-item>
        <swiper-item wx:if="{{!images.length}}">
          <view class="gallery__placeholder" aria-label="商品暂无图片">Harbor Market</view>
        </swiper-item>
      </swiper>

      <scroll-view wx:if="{{images.length > 1}}" class="gallery__thumbs" scroll-x="true" show-scrollbar="false">
        <view class="gallery__thumb-row">
          <button
            wx:for="{{images}}"
            wx:key="id"
            class="gallery__thumb {{activeImageIndex == index ? 'gallery__thumb--active' : ''}}"
            data-index="{{index}}"
            bindtap="selectGalleryImage"
            aria-label="查看第 {{index + 1}} 张商品图片"
          >
            <image src="{{item.displayUrl}}" mode="aspectFill" aria-hidden="true" />
          </button>
        </view>
      </scroll-view>
    </view>

    <view class="page-shell product-content">
      <view class="surface product-summary">
        <view class="product-summary__meta">
          <text>{{product.category.name}}</text>
          <text wx:if="{{product.featured}}" class="product-summary__featured">推荐</text>
        </view>
        <text class="page-heading product-summary__name">{{product.name}}</text>
        <text wx:if="{{product.subtitle}}" class="product-summary__subtitle">{{product.subtitle}}</text>
        <view class="product-summary__price-row">
          <text class="price product-summary__price">{{displayPrice}}</text>
          <text wx:if="{{marketPrice}}" class="product-summary__market-price">{{marketPrice}}</text>
          <text class="product-summary__stock">{{stockLabel}}</text>
        </view>
        <view wx:if="{{product.tags.length}}" class="tag-row" aria-label="商品标签">
          <text wx:for="{{product.tags}}" wx:key="*this" class="tag">{{item}}</text>
        </view>
      </view>

      <view wx:if="{{specifications.length}}" class="surface choice-card" aria-label="选择规格">
        <text id="choice-title" class="section-title">选择规格</text>
        <view wx:for="{{specifications}}" wx:key="code" class="specification">
          <view class="specification__heading">
            <text class="specification__name">{{item.name}}</text>
            <text class="specification__mode">{{item.requirementLabel}} · {{item.modeLabel}}</text>
          </view>
          <view class="option-grid" aria-role="group" aria-label="{{item.name}}选项">
            <button
              wx:for="{{item.options}}"
              wx:for-item="option"
              wx:key="code"
              class="option-button {{option.selected ? 'option-button--selected' : ''}}"
              data-specification-code="{{item.code}}"
              data-option-code="{{option.code}}"
              bindtap="selectOption"
              aria-label="{{option.name}}{{option.priceDeltaLabel}}{{option.selected ? '，已选择' : ''}}"
            >
              <text>{{option.name}}</text>
              <text wx:if="{{option.priceDeltaLabel}}" class="option-button__price">{{option.priceDeltaLabel}}</text>
            </button>
          </view>
        </view>
        <text wx:if="{{selectionText}}" class="selection-summary">已选：{{selectionText}}</text>
        <text wx:if="{{selectionHint}}" class="selection-hint" aria-role="alert">{{selectionHint}}</text>
      </view>

      <view class="surface quantity-card" aria-label="购买数量">
        <view>
          <text id="quantity-title" class="section-title">购买数量</text>
          <text class="quantity-card__help">每次最多添加 {{maxQuantity}} 件</text>
        </view>
        <quantity-stepper
          value="{{quantity}}"
          min="{{1}}"
          max="{{maxQuantity}}"
          disabled="{{!canAddToCart}}"
          bind:change="changeQuantity"
        />
      </view>

      <view wx:if="{{product.selling_points.length}}" class="surface detail-card">
        <text class="section-title">商品亮点</text>
        <view class="selling-points">
          <view wx:for="{{product.selling_points}}" wx:key="*this" class="selling-point">
            <text class="selling-point__marker" aria-hidden="true">✓</text>
            <text>{{item}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{product.description}}" class="surface detail-card">
        <text class="section-title">商品说明</text>
        <text class="detail-copy" user-select="true">{{product.description}}</text>
      </view>

      <view wx:if="{{product.ingredients || product.allergen_info}}" class="surface detail-card">
        <view wx:if="{{product.ingredients}}" class="detail-row">
          <text class="detail-row__label">配料</text>
          <text class="detail-copy" user-select="true">{{product.ingredients}}</text>
        </view>
        <view wx:if="{{product.allergen_info}}" class="detail-row">
          <text class="detail-row__label">过敏原提示</text>
          <text class="detail-copy" user-select="true">{{product.allergen_info}}</text>
        </view>
      </view>
    </view>

    <view class="product-actions" aria-role="group" aria-label="商品操作">
      <button class="secondary-button product-actions__cart" bindtap="openCart" aria-label="查看购物车">
        购物车
      </button>
      <button
        class="primary-button product-actions__add"
        disabled="{{!canAddToCart || adding}}"
        bindtap="addToCart"
        aria-label="{{canAddToCart ? '加入购物车' : selectionHint || '商品暂不可购买'}}"
      >{{adding ? '正在添加…' : canAddToCart ? '加入购物车' : '暂不可购买'}}</button>
    </view>
  </block>
</view>
